<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <application android:label="MobiGas Vendor">
        <!-- LocationService.startTracking() streams the rider's position
             during an active delivery. The foreground service and its
             persistent notification are what keep the stream alive once
             the vendor backgrounds the app — this is why we need no
             ACCESS_BACKGROUND_LOCATION, and no Play background-location
             review. foregroundServiceType is mandatory from Android 14. -->
        <service
            android:name="com.baseflow.geolocator.GeolocatorLocationService"
            android:foregroundServiceType="location"
            android:exported="false"
            tools:replace="android:foregroundServiceType" />
    </application>
</manifest>
